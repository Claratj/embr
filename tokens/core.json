{
  "space": {
    "$type": "dimension",
    "0": { "$value": "0px" },
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "24px" },
    "6": { "$value": "32px" },
    "7": { "$value": "48px" },
    "8": { "$value": "64px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "4px" },
    "md": { "$value": "8px" },
    "lg": { "$value": "12px" },
    "full": { "$value": "9999px" }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "heading": { "$value": ["Montserrat", "system-ui", "sans-serif"] },
      "body": { "$value": ["Mulish", "system-ui", "sans-serif"] }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "12px" },
      "sm": { "$value": "14px" },
      "md": { "$value": "16px" },
      "lg": { "$value": "18px" },
      "xl": { "$value": "20px" },
      "2xl": { "$value": "24px" },
      "3xl": { "$value": "32px" },
      "4xl": { "$value": "40px" }
    }
  },
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": {
        "color": "#1A141614",
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px"
      }
    },
    "md": {
      "$value": {
        "color": "#1A14161f",
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "12px",
        "spread": "-2px"
      }
    }
  }
}
