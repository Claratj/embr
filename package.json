{
  "name": "embr-ui",
  "version": "0.0.0",
  "description": "Embr — an accessible, token-driven React design system.",
  "license": "MIT",
  "author": "Clara Toloba <clara@claratoloba.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Claratj/embr.git"
  },
  "homepage": "https://github.com/Claratj/embr#readme",
  "keywords": [
    "design-system",
    "design-tokens",
    "dtcg",
    "react",
    "tailwind",
    "accessibility"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./preset.css": "./dist/preset.css",
    "./tokens.css": "./dist/tokens.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:tokens": "node scripts/build-tokens.js",
    "predev": "npm run build:tokens",
    "dev": "storybook dev -p 6006",
    "prebuild": "npm run build:tokens",
    "clean": "node scripts/clean.js",
    "build": "npm run clean && vite build && tsc -p tsconfig.build.json && node scripts/build-css.js",
    "prebuild-storybook": "npm run build:tokens",
    "build-storybook": "storybook build",
    "pretest": "npm run build:tokens",
    "test": "vitest run",
    "changeset": "changeset",
    "version": "changeset version",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.5.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.0",
    "style-dictionary": "^5.5.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
